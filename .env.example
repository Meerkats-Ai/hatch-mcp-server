# Hatch API Key (required)
HATCH_API_KEY=your_api_key_here

# Optional: Custom API URL (defaults to https://api.hatchhq.ai)
# HATCH_API_URL=https://custom-api.hatchhq.ai

# Retry configuration
HATCH_RETRY_MAX_ATTEMPTS=3
HATCH_RETRY_INITIAL_DELAY=1000
HATCH_RETRY_MAX_DELAY=10000
HATCH_RETRY_BACKOFF_FACTOR=2
